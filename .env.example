# Environment Configuration Template

# Application Environment
NODE_ENV=development
PORT=3000

# Logging
DEBUG=true
LOG_LEVEL=debug

# Docker Build
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=nodejs-app
DOCKER_IMAGE_TAG=latest

# CI/CD Pipeline (Use GitHub Secrets in production)
# DOCKERHUB_USERNAME=your_username_here
# DOCKERHUB_TOKEN=your_token_here

# Database Configuration (if using database)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nodejs_app
# DB_USER=app_user
# DB_PASSWORD=your_password_here

# API Configuration
# API_URL=http://localhost:3000
# API_TIMEOUT=30000

# Session Configuration (if needed)
# SESSION_SECRET=your_secret_here
# SESSION_TIMEOUT=3600

# Monitoring & Logging
# SENTRY_DSN=https://your_sentry_key@sentry.io/project_id
# LOG_FORMAT=json

# Security Headers
# CORS_ORIGIN=http://localhost:3000
# HELMET_ENABLED=true

# Third-party Services (if applicable)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SENDGRID_API_KEY=SG.your_key_here
# AWS_ACCESS_KEY_ID=your_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_here

# Feature Flags
# FEATURE_NEW_AUTH=false
# FEATURE_BETA_API=false

# Performance
# MAX_REQUEST_SIZE=10mb
# RATE_LIMIT_WINDOW=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ⚠️ IMPORTANT SECURITY NOTES ⚠️
# 1. NEVER commit this file with real secrets to version control
# 2. Always use this .env.example as a template
# 3. Create a real .env file locally (ignored by .gitignore)
# 4. Use GitHub Secrets for CI/CD environment variables
# 5. For production, use environment variable management system
# 6. Rotate secrets regularly
# 7. Never log sensitive data
# 8. Use strong random values for secrets (especially SESSION_SECRET)
